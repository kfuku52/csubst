    analyze.add_argument('--epistasis_pdb', metavar='PATH/PDB_CODE/besthit', default='', type=str,
                         help='default=%(default)s: Structure source for analyze-time epistasis degree generation. '
                              'PATH: local structure file; PDB code: fetched from PDB; '
