def strtobool(value):
    if isinstance(value, bool):
        return value
    value = str(value).strip().lower()
    if value in {'y', 'yes', 't', 'true', 'on', '1'}:
        return True
    if value in {'n', 'no', 'f', 'false', 'off', '0'}:
        return False
    raise argparse.ArgumentTypeError('invalid truth value: {}'.format(value))


